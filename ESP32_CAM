// ─── Camera Init ─────────────────────────────────────────────
bool initCamera() {
  camera_config_t config;

  config.ledc_channel = LEDC_CHANNEL_0;
  config.ledc_timer   = LEDC_TIMER_0;
  config.pin_d0 = Y2_GPIO_NUM; config.pin_d1 = Y3_GPIO_NUM;
  config.pin_d2 = Y4_GPIO_NUM; config.pin_d3 = Y5_GPIO_NUM;
  config.pin_d4 = Y6_GPIO_NUM; config.pin_d5 = Y7_GPIO_NUM;
  config.pin_d6 = Y8_GPIO_NUM; config.pin_d7 = Y9_GPIO_NUM;
  config.pin_xclk = XCLK_GPIO_NUM;
  config.pin_pclk = PCLK_GPIO_NUM;
  config.pin_vsync = VSYNC_GPIO_NUM;
  config.pin_href = HREF_GPIO_NUM;
  config.pin_sscb_sda = SIOD_GPIO_NUM;
  config.pin_sscb_scl = SIOC_GPIO_NUM;
  config.pin_pwdn = PWDN_GPIO_NUM;
  config.pin_reset = RESET_GPIO_NUM;

  config.xclk_freq_hz = 20000000;
  config.pixel_format = PIXFORMAT_JPEG;

  if (psramFound()) {
    config.frame_size = FRAMESIZE_UXGA;
    config.jpeg_quality = 10;
    config.fb_count = 2;
  } else {
    config.frame_size = FRAMESIZE_SVGA;
    config.jpeg_quality = 12;
    config.fb_count = 1;
  }

  if (esp_camera_init(&config) != ESP_OK) {
    Serial.println("[CAM] Init failed");
    return false;
  }

  Serial.println("[CAM] Ready");
  return true;
}

// ─── SD Card Init ────────────────────────────────────────────
bool initSD() {
  if (!SD_MMC.begin()) return false;
  if (SD_MMC.cardType() == CARD_NONE) return false;
  Serial.println("[SD] Ready");
  return true;
}

// ─── Save Image ──────────────────────────────────────────────
String saveToSD(camera_fb_t *fb) {
  imageCount++;
  String filename = "/IMG_" + String(imageCount) + ".jpg";

  File file = SD_MMC.open(filename.c_str(), FILE_WRITE);
  if (!file) return "";

  file.write(fb->buf, fb->len);
  file.close();

  Serial.println("[SD] Saved " + filename);
  return filename;
}

// ─── Send to Telegram ────────────────────────────────────────
void sendToTelegram(camera_fb_t *fb, String filename, int shotNum) {

  String caption = "Shot #" + String(shotNum);

  fb_global = fb;
  fb_index = 0;

  String res = bot.sendPhotoByBinary(
    CHAT_ID,
    "image/jpeg",
    fb->len,
    moreDataAvailable,
    getNextByte,
    nullptr,   // ✅ FIX: no buffer function
    nullptr
  );

  if (res.length() > 0) {
    Serial.println("[TG] Sent OK");
  } else {
    Serial.println("[TG] Failed");
  }
}

// ─── Capture Loop ────────────────────────────────────────────
void runCaptureLoop() {

  bot.sendMessage(CHAT_ID, "Trigger ON - capturing...", "");

  int shot = 0;

  while (digitalRead(TRIGGER_PIN) == HIGH) {

    shot++;

    camera_fb_t *fb = esp_camera_fb_get();
    if (!fb) continue;

    String filename = saveToSD(fb);

    sendToTelegram(fb, filename, shot);

    esp_camera_fb_return(fb);

    delay(CAPTURE_INTERVAL);
  }

  bot.sendMessage(CHAT_ID, "Trigger OFF - stopped", "");
}

// ─── Setup ───────────────────────────────────────────────────
void setup() {

  WRITE_PERI_REG(RTC_CNTL_BROWN_OUT_REG, 0);

  Serial.begin(115200);

  pinMode(TRIGGER_PIN, INPUT_PULLDOWN);

  initCamera();
  initSD();

  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
  }

  client.setInsecure(); // important

  bot.sendMessage(CHAT_ID, "ESP32-CAM Ready", "");
}

// ─── Loop ────────────────────────────────────────────────────
void loop() {

  if (digitalRead(TRIGGER_PIN) == HIGH) {
    runCaptureLoop();
    delay(500);
  }

  delay(50);
}
